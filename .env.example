# LMS Configuration
LMS_URL=https://lms.ssn.edu.in
LMS_USERNAME=your_email@ssn.edu.in
# If your password contains $, use $$ or \$ to escape
LMS_PASSWORD=your_password

# AI Provider (google | anthropic | openai)
AI_PROVIDER=google
GOOGLE_API_KEY=your_google_api_key
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Student Info (for document headers)
STUDENT_NAME=Your Full Name
STUDENT_REG_NO=2410112
STUDENT_DEPT=Computer Science and Engineering
STUDENT_YEAR=2026

# Paths (relative to project root, or absolute)
DATABASE_PATH=data/lms_mcp.db
GENERATED_DIR=generated

# Server
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8080
POLL_INTERVAL_MINUTES=30

# Logging (DEBUG | INFO | WARNING)
LOG_LEVEL=INFO
